<% local_assigns[:additional_breadcrumb] = t('ldap_groups.synchronized_filters.add_new') %>
<% html_title(t(:label_administration), t('ldap_groups.synchronized_filters.add_new')) -%>

<div class="bg-white p-4 mb-4 rounded-border" style="border: 1px solid #000;">
  <%= toolbar title: t('ldap_groups.synchronized_filters.add_new'), title_class: "color-orange" %>
  <%= labelled_tabular_form_for @filter,
                                as: :synchronized_filter,
                                url: { action: :create } do |f| %>

    <%= render partial: 'form', locals: { f: f } %>
    <p class="m-0">
      <%= styled_button_tag t(:button_create), class: '-primary -with-icon icon-checkmark custom-secondary-button rounded-border m-0 mr-2 px-3' %>
      <%= link_to t(:button_cancel), ldap_groups_synchronized_groups_path, class: 'button -with-icon icon-cancel rounded-border m-0' %>
    </p>
  <% end %>
</div>
