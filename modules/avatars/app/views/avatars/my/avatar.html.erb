<% breadcrumb_paths(t(:label_my_account), t(:button_change_avatar)) %>

<div class="bg-white p-4 mb-4 rounded-border" style="border: 1px solid #000;">
  <%= toolbar title: t(:button_change_avatar), title_class: "color-orange" %>
  <% html_title t(:label_my_account), t(:button_change_avatar) %>

  <% @manager = ::OpenProject::Avatars::AvatarManager %>
  <% @target_avatar_path = edit_my_avatar_path %>
  <%= form_tag(edit_my_avatar_path, method: :put, name: 'avatar_form', multipart: true) do %>
    <%= render partial: 'avatars/users/avatar' %>
  <% end %>
</div>
