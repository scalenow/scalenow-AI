<% html_title t(:label_administration), "#{t(:label_edit)} #{I18n.t((@project.nil? ? :caption_default_rate_history_for : :caption_rate_history_for), user: ' ')} #{@user.name}" %>

<div class="bg-white p-4 mb-4 rounded-border" style="border: 1px solid #000;">
  <%= toolbar title_class: "color-orange", title: (@project.nil? ? t(:caption_default_rate_history_for, user: @user.name) :  t(:caption_rate_history_for_project, user: @user.name, project: @project.name) ) %>

  <%- default_rate = @user.current_default_rate -%>
  <% if default_rate%>
  <p><strong><%= t(:label_current_default_rate) %>:</strong> <%= number_to_currency(default_rate.rate)%></p>
  <% end %>

  <div id="rates-form-container" data-item-count="<%= @rates.count %>">
    <%= labelled_tabular_form_for @user, url: {action: 'update', project_id: @project}, method: :put do |f| %>
      <%= back_url_hidden_field_tag %>
      <%= error_messages_for 'user' %>
      <%- @rates.each do |rate| -%>
        <%- @rate = rate -%>
        <%= error_messages_for 'rate' %>
      <%- end -%>
      <div class="generic-table--container">
        <div class="generic-table--results-container">
          <table class="generic-table rates" width="200px">
            <colgroup>
              <col opHighlightCol>
              <col opHighlightCol>
              <col>
            </colgroup>
            <thead>
              <tr>
                <th>
                  <div class="generic-table--sort-header-outer">
                    <div class="generic-table--sort-header">
                      <span>
                        <%= Rate.human_attribute_name(:valid_from) %>
                      </span>
                    </div>
                  </div>
                </th>
                <th class="currency">
                  <div class="generic-table--sort-header-outer">
                    <div class="generic-table--sort-header">
                      <span>
                        <%= Rate.model_name.human %>
                      </span>
                    </div>
                  </div>
                </th>
                <th><div class="generic-table--empty-header"></div></th>
              </tr>
            </thead>
            <tbody id="rates_body" class="subform-container">
              <%= render partial: "hourly_rates/rate", object: HourlyRate.new(valid_from: Date.current), locals: { templated: true } %>
              <%- @rates.each_with_index do |rate, index| -%>
                <%= render partial: 'rate', object: rate, locals: {index: index} %>
              <%- end -%>
            </tbody>
          </table>
        </div>
      </div>
      <div class="wp-inline-create-button">
        <a href="#" class="add-row-button wp-inline-create--add-link">
          <%= op_icon('icon icon-add') %>
          <%= t(:button_add_rate) %>
        </a>
      </div>
      <div class="generic-table--action-buttons">
        <%= styled_button_tag t(:button_save), class: '-with-icon icon-checkmark custom-secondary-button rounded-border m-0' %>
      </div>
    <% end %>
  </div>  
</div>

<%= nonced_javascript_tag do %>
  (function($) {
    $(document).ready(function() {
      const formContainer = $('#rates-form-container');
      const container = $('#rates_body');
      const templateEl = container.find('.subform-row-template').first();
      templateEl.hide();
      const template = templateEl[0].outerHTML;
      let rowIndex = parseInt(formContainer.data('item-count'));

      // Delete row handler
      container.on('click', '.delete-row-button', function(evt) {
        evt.preventDefault();
        $(this).closest('.subform-row').remove();
        return false;
      });

      // Add new row handler
      formContainer.on('click', '.add-row-button', function(evt) {
        evt.preventDefault();
        const row = $(template.replace(/INDEX/g, rowIndex.toString()));
        row.removeClass('subform-row-template').show();
        row.find('input.costs-date-picker').prop('required', true);
        row.find('input[id^="cost_type_new_rate_attributes"]').prop('required', true);

        container.append(row);
        rowIndex += 1;

        // Assuming OpenProject.getPluginContext() is available globally
        OpenProject.getPluginContext().then(function(pluginContext) {
          pluginContext.bootstrap(row[0]);
        });

        setTimeout(function() {
          container.find('.subform-row:last-child input:first').focus();
        }, 10);

        return false;
      });
    });
  }(jQuery));
<% end %>
