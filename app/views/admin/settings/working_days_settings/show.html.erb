<div class="custom-toolbar-title">
  <%= toolbar title: t(:label_working_days) %>
</div>

<div class="op-toast -warning">
  <div class="op-toast--content">
    <p>
    <%= t("working_days.warning").html_safe %>
    </p>
  </div>
</div>

<br>
<%= styled_form_tag(
      admin_settings_working_days_path,
      method: :patch,
      class: 'op-working-days-admin-settings'
    ) do %>

  <section class="form--section form-custom">
    <fieldset class="form--fieldset">
      <legend class="form--fieldset-legend"><%= t('settings.working_days.section_work_week') %></legend>

      <p>
        <%= t("working_days.info").html_safe %>
      </p>

      <div class="form--field op-working-days-admin-settings--day-selectors" id="setting_working_days">
        <%= setting_multiselect :working_days,

              I18n.t('date.day_names').rotate.zip(WeekDay::DAY_RANGE),
              direction: :horizontal %>
      </div>

    </fieldset>

    <fieldset class="form--fieldset">
      <legend class="form--fieldset-legend"><%= t('settings.working_days.section_holidays_and_closures') %></legend>

      <p>
        <%= t("working_days.instance_wide_info").html_safe %>
      </p>
      <%= angular_component_tag 'op-non-working-days-list',
                                data: { modified_non_working_days: @modified_non_working_days } %>

    </fieldset>
    <%= styled_button_tag t(:button_apply_changes), class: '-primary -with-icon icon-checkmark custom-secondary-button rounded-border' %>
  </section>



<% end %>

<style>
  .custom-toolbar-title .title-container h2 {
    color: #ff7f5d;
  }

  .form-custom {
    background: #fff;
    padding: 12px;
    border-radius: 33px;
    border: 2px solid #000;
  }

  .op-toast.-warning {
    background-color: #f3f6f9 !important; /* Override all other styles with !important */
    border: 1px solid black;
    border-radius: 33px;
  }

  .fc-event td {
    background-color: #f3f6f9 !important;
    color: black !important; /* Ensure the text color is black */
  }
</style>
