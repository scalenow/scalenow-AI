<div class="row">
  <% @menu_nodes.sort_by(&:caption).zip(@images).each_slice(4) do |menu_node_group| %>
    <% menu_node_group.each do |menu_node, image| %>
      <div class="col-md-4 project-card"> <!-- Adjusted column width for 4 per row -->
        <%= link_to menu_node.url, class: 'text-body', style: 'text-decoration: none;' do %> <!-- Wrapped entire card -->
          <div class="card card-rounded-square">
            <div class="card-body d-flex flex-column text-center"> <!-- Center content -->
              <div class="mb-auto"></div> <!-- Pushes content down -->
              <h5 class="mt-5 fs-15 d-flex align-items-center justify-content-center">
                <%= op_icon("menu-block--icon icon3 icon-#{(menu_node.icon || '')}") %>
                <span class="menu-block--title ml-2"> <%= menu_node.caption %> </span>
              </h5>
              <div class="mt-2 img-box"> <!-- Div for the image -->
                <%= image_tag "administration_images/#{image}", class: 'img-fluid card-image', alt: "#{image}" %> <!-- Display each image with a custom class -->
              </div>
              <div class="mt-auto"></div> <!-- Keeps content pushed down -->
            </div>
            <!-- end card body -->
            <!-- end card footer -->
          </div>
        <% end %>
        <!-- end card -->
      </div>
      <!-- end col -->
    <% end %>
  <% end %>
</div>
<!-- end row -->

<style>
.card-rounded-square {
  position: relative;
  width: 100%;
  padding-top: 75%; /* Maintain aspect ratio */
  border-radius: 33px; /* Rounded corners */
  border: 2px solid black;
  overflow: hidden; /* Ensure content fits within the rounded square */
}

.card {
  height: 300px;
  cursor: pointer; /* Indicate that the entire card is clickable */
}

.card-rounded-square .card-body {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 0; /* Adjust padding to make card smaller */
}

.img-box {
  height: 222px;
  width: 270px;
}

.img-box img {
  object-fit: contain;
  height: 100%;
}

.menu-block--icon:before {
  font-size: 29px;
  padding: 0;
  color: #808080;
}

.ml-2 {
  margin-left: 0.5rem; /* Bootstrap class for margin-left */
}
</style>
