<div class="row">
  <div class="col-lg-12">
    <div class="tab-content text-muted">
      <div class="tab-pane fade show active" id="project-overview" role="tabpanel">
        <div class="row">
          <div class="col-xl-9 col-lg-8">
            <div class="card">
              <div class="card-body">
                <div class="text-muted">
                  <%= render partial: "homescreen/blocks/welcome" , locals: {} %>
                  <!-- <ul class="ps-4 vstack gap-2">
                  </ul>
                  <div>
                    <button type="button" class="btn btn-link link-success p-0">Read more</button>
                  </div> -->

                  <div class="pt-3 border-top-dashed mt-4">
                    <div class="row gy-3">
                      <div class="col-lg-4 col-sm-4">
                        <div>
                          <p class="mb-2 text-uppercase fw-medium color-orange">My Account<br></p>
                          <%= render partial: "homescreen/blocks/my_account" , locals: {} %>
                        </div>
                      </div>

                      <div class="col-lg-8 col-sm-8">
                        <div>
                          <p class="mb-2 text-uppercase fw-medium color-orange">Latest News<br></p>
                          <%= render partial: "homescreen/blocks/news" , locals: {} %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div> <!-- end card body -->
            </div> <!-- end card -->

            <div class="row">
              <div class="col-lg-6 col-sm-6">
                <div class="card">
                  <div class="card-body">
                    <div>
                      <h2 class="editable-toolbar-title--fixed color-orange text-uppercase">scalenow-AI community</h2>
                      <%= render partial: "homescreen/blocks/community" , locals: {} %>
                    </div>
                  </div> <!-- end card body -->
                </div> <!-- end card -->
              </div> <!-- end col -->

              <div class="col-lg-6 col-sm-6">
                <div class="card">
                  <div class="card-body">
                    <div>
                      <%= render partial: "homescreen/blocks/administration" , locals: {} %>
                    </div>
                  </div> <!-- end card body -->
                </div> <!-- end card -->
              </div> <!-- end col -->
            </div> <!-- end row -->

            <!-- <div class="card">
              <div class="card-body">
                <h2 class="editable-toolbar-title--fixed text-uppercase color-orange mb-3">New Features</h2>
                <%#= render partial: "homescreen/blocks/new_features" , locals: {} %>
              </div>
            </div> -->
          </div> <!-- end col -->

          <div class="col-xl-3 col-lg-4">
            <div class="card">
              <div class="card-header align-items-center d-flex border-bottom-dashed">
                <h4 class="card-title mb-0 flex-grow-1 text-uppercase color-orange">Projects<br></h4>
              </div>
              <div class="card-body">
                <div data-simplebar="init" style="height: 235px;" class="mx-n3 px-3 simplebar-scrollable-y">
                  <div class="simplebar-wrapper" style="margin: 0px -16px;">
                    <div class="simplebar-height-auto-observer-wrapper">
                      <div class="simplebar-height-auto-observer"></div>
                    </div>

                    <div class="simplebar-mask">
                      <div class="simplebar-offset" style="right: 0px; bottom: 0px;">
                        <div class="simplebar-content-wrapper" tabindex="0" role="region" aria-label="scrollable content" style="height: 100%; overflow: hidden scroll;">
                          <div class="simplebar-content" style="padding: 0px 16px;">
                            <%= render partial: "homescreen/blocks/projects" , locals: {} %>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="simplebar-placeholder" style="width: 228px; height: 284px;"></div>
                  </div>

                  <div class="simplebar-track simplebar-horizontal" style="visibility: hidden;">
                    <div class="simplebar-scrollbar" style="width: 0px; display: none;"></div>
                  </div>

                  <div class="simplebar-track simplebar-vertical" style="visibility: visible;">
                    <div class="simplebar-scrollbar" style="height: 194px; transform: translate3d(0px, 0px, 0px); display: block;"></div>
                  </div>
                </div>

                <div class="widget-box--blocks--buttons mt-3">
                  <% if User.current.allowed_globally?(:add_project) %>
                    <%= link_to new_project_path,
                          { class: 'button -primary custom-secondary-button rounded-border mb-2 mr-2',
                            aria: {label: t(:label_project_new)},
                            title: t(:label_project_new)} do %>
                      <%= op_icon('button--icon icon-add') %>
                      <span class="button--text"><%= Project.model_name.human %></span>
                    <% end %>
                  <% end %>
                
                  <%# If any project exists %>
                  <% unless @newest_projects.empty? %>
                    <%= link_to t(:label_project_view_all), projects_path,
                                class: 'button -highlight-inverted custom-secondary-button rounded-border mb-2',
                                title: t(:label_project_view_all) %>
                  <% end %>
                </div>
              </div> <!-- end card body -->
            </div> <!-- end card -->

            <% if User.current.admin? %>
            <div class="card">
              <div class="card-header align-items-center d-flex border-bottom-dashed">
                <h4 class="card-title mb-0 flex-grow-1 text-uppercase color-orange">Users<br></h4>
              </div>
              <div class="card-body">
                <div data-simplebar="init" style="height: 235px;" class="mx-n3 px-3 simplebar-scrollable-y">
                  <div class="simplebar-wrapper" style="margin: 0px -16px;">
                    <div class="simplebar-height-auto-observer-wrapper">
                      <div class="simplebar-height-auto-observer"></div>
                    </div>

                    <div class="simplebar-mask">
                      <div class="simplebar-offset" style="right: 0px; bottom: 0px;">
                        <div class="simplebar-content-wrapper" tabindex="0" role="region" aria-label="scrollable content" style="height: 100%; overflow: hidden scroll;">
                          <div class="simplebar-content" style="padding: 0px 16px;">
                            <%= render partial: "homescreen/blocks/users" , locals: {} %>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="simplebar-placeholder" style="width: 228px; height: 284px;"></div>
                  </div>

                  <div class="simplebar-track simplebar-horizontal" style="visibility: hidden;">
                    <div class="simplebar-scrollbar" style="width: 0px; display: none;"></div>
                  </div>

                  <div class="simplebar-track simplebar-vertical" style="visibility: visible;">
                    <div class="simplebar-scrollbar" style="height: 194px; transform: translate3d(0px, 0px, 0px); display: block;"></div>
                  </div>
                </div>

                <div class="widget-box--buttons mt-3 ml-3">
                  <% if User.current.admin? %>
                    <%= link_to new_user_path, class: 'button -primary custom-secondary-button rounded-border m-0' do %>
                      <%= op_icon('button--icon icon-add') %>
                      <span class="button--text"><%= t(:label_invite_user) %></span>
                    <% end %>
                  <% end %>
                </div>
              </div> <!-- end card body -->
            </div> <!-- end card -->
            <% end %>

            <div class="card">
              <div class="card-body">
                <% if show_homescreen_links? && @homescreen[:links].any? %>
                  <section class="homescreen--links">
                    <% @homescreen[:links].each do |link| %>
                      <% title = I18n.t(link[:label], scope: 'homescreen.links', default: link[:label]) %>
                      <a class="homescreen--links--item" href="<%= link[:url] %>" target="_blank" title="<%= title %>">
                        <%= op_icon(link[:icon]) %>
                        <%= title %>
                      </a>
                    <% end %>
                  </section>
                <% end %>
                <%= call_hook :homescreen_after_links %>
              </div> <!-- end card body -->
            </div> <!-- end card -->
          </div> <!-- end col -->
        </div> <!-- end row -->
      </div> <!-- end tab pane -->
    </div> <!-- end tab content -->
  </div> <!-- end col -->
</div> <!-- end row -->
