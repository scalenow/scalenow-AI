++#%><!DOCTYPE html>
<% show_decoration = params["layout"].nil? %>
<html xmlns="http://www.w3.org/1999/xhtml"
      lang="<%= I18n.locale.to_s %>"
      xml:lang="<%= I18n.locale.to_s %>"
      class="<%= "in_modal" unless show_decoration %>">
<head>
  <%= render partial: "layouts/common_head" %>
  <!-- project specific tags -->
  <%= call_hook :view_layouts_base_html_head %>
  <!-- page specific tags -->
  <%= content_for(:header_tags) if content_for?(:header_tags) %>
  <meta name="current_menu_item" content="<%= current_menu_item %>"/>
  <%# Disable prefetching for now %>
  <meta name="turbo-prefetch" content="false">

  <!-- Session validation script starts -->
  <script>
    // --- 1. INSTANT REDIRECT CHECK (The "Hop") --------------------------
    // Run this IMMEDIATELY, before the page fully loads.
    (function checkInstantRedirect() {
      const savedRedirect = sessionStorage.getItem("post_auth_redirect");

      if (savedRedirect) {
        // Verify we aren't already there (prevents loops)
        if (window.location.href !== savedRedirect) {
          console.log("⚡ [SESSION] Instant Hop! Redirecting to:", savedRedirect);

          // Clear the memory
          sessionStorage.removeItem("post_auth_redirect");

          // HIDE the body so the user doesn't see the Home Page flash
          document.documentElement.style.visibility = 'hidden';

          // GO THERE NOW
          window.location.href = savedRedirect;

          // Stop the rest of the script from running
          throw new Error("Redirecting...");
        } else {
          // We arrived! Clean up.
          sessionStorage.removeItem("post_auth_redirect");
        }
      }
    })();

    // --- Shared helpers -------------------------------------------------

    function deleteAllSSOCookies() {
      document.cookie.split(";").forEach(cookie => {
        const name = cookie.split("=")[0].trim();
        document.cookie = `${name}=; Max-Age=0; path=/; domain=${window.location.hostname};`;
      });
      sessionStorage.clear();
    }

    function getSessionToken() {
      // Prefer access_token (normal practice), fallback to id_token
      const access = sessionStorage.getItem("access_token");
      const id = sessionStorage.getItem("id_token");
      const token = access || id || null;
      console.log("🔑 [SESSION] Using token type:",
        access ? "access_token" : (id ? "id_token" : "none"));
      return token;
    }

    function redirectToLogin(reason) {
      console.warn("🚪 [SESSION] Redirecting to login. Reason:", reason);

      // 1. Capture the URL *BEFORE* we clear storage
      const intendedUrl = window.location.href;

      deleteAllSSOCookies();

      // 2. SAVE THE URL TO STORAGE
      sessionStorage.setItem("post_auth_redirect", intendedUrl);
      console.log("📍 [SESSION] Saved deep link to storage:", intendedUrl);

      const loginUrl =
        "https://www.scalenowai.com.au/realms/scalenowAI/protocol/openid-connect/auth"
        + "?client_id=scalenowAI"
        + "&redirect_uri=https://www.scalenowai.com.au/oauth/oidc/callback"
        + "&response_type=code"
        + "&scope=openid%20email%20profile";
        // removed hardcoded state=rails to rely on sessionStorage

      window.location.href = loginUrl;
    }

    function redirectToKeycloakLogout(reason) {
      console.warn("🚪 [SESSION] Redirecting to Keycloak logout. Reason:", reason);

      // 1. Read id_token BEFORE clearing storage
      const rawIdToken = sessionStorage.getItem("id_token");

      // Treat "null"/"undefined"/empty as "no token"
      const hasIdToken =
        rawIdToken &&
        rawIdToken !== "null" &&
        rawIdToken !== "undefined";

      // 2. Clear storage
      sessionStorage.clear();
      localStorage.clear();

      // 3. Best-effort cookie cleanup
      document.cookie.split(";").forEach(c => {
        const name = c.split("=")[0].trim();
        if (name) {
          document.cookie = `${name}=; Max-Age=0; path=/; domain=${window.location.hostname}`;
        }
      });

      // 4. Where to send the user AFTER Keycloak logout
      const redirectUri = encodeURIComponent("https://www.scalenowai.com.au/login");

      // 5. Build logout URL
      let logoutUrl =
        "https://www.scalenowai.com.au/realms/scalenowAI/protocol/openid-connect/logout" +
        "?post_logout_redirect_uri=" + redirectUri;

      // Only add id_token_hint if we actually have a token
      if (hasIdToken) {
        logoutUrl += "&id_token_hint=" + encodeURIComponent(rawIdToken);
      }

      console.log("🔗 [SESSION] Redirecting to:", logoutUrl);
      window.location.href = logoutUrl;
    }

    // --- Capture tokens from URL hash (after FastAPI callback) ----------

    function captureTokens() {
      if (window.location.hash) {
        console.log("🚀 [SESSION] Capturing tokens from URL hash...");
        const params = new URLSearchParams(window.location.hash.substring(1));
        const idToken = params.get("id_token");
        const accessToken = params.get("access_token");

        console.log("🪪 [SESSION] New ID token present:", !!idToken);
        console.log("🛡️ [SESSION] New access token present:", !!accessToken);

        if (idToken) {
          sessionStorage.setItem("id_token", idToken);
          try {
            const payload = JSON.parse(atob(idToken.split('.')[1]));
            const username = payload.preferred_username
              || (payload.email ? payload.email.split('@')[0] : "anonymous");
            const email = payload.email || "";
            sessionStorage.setItem("username", username);
            sessionStorage.setItem("email", email);
          } catch (err) {
            console.error("❌ [SESSION] Error decoding ID token:", err);
          }
        }

        if (accessToken) {
          sessionStorage.setItem("access_token", accessToken);
        }

        // Clean up URL
        if (window.history.replaceState) {
          window.history.replaceState(null, null, window.location.pathname);
        }
      } else {
        console.log("⚠️ [SESSION] No tokens in URL hash. Using sessionStorage if available.");
      }

      const storedId = sessionStorage.getItem("id_token");
      const storedAccess = sessionStorage.getItem("access_token");

      if (!storedId && !storedAccess) {
        console.log("🔒 [SESSION] No tokens at all → redirecting to login.");
        redirectToLogin("No tokens in storage");
      }
    }

    // --- Periodic validation against FastAPI ----------------------------

    async function validateSession() {
      console.log("📡 [SESSION CHECK] Calling /validate-session ...");
      const token = getSessionToken();

      if (!token) {
        console.warn("⛔ [SESSION CHECK] No token in storage.");
        redirectToLogin("Missing token in validateSession");
        return;
      }

      try {
        const response = await fetch("https://www.scalenowai.com.au/validate-session", {
          method: "GET",
          headers: {
            "Authorization": `Bearer ${token}`
          }
        });

        console.log("📥 [SESSION CHECK] HTTP status:", response.status);

        // Backend contract: 401 => expired or revoked
        if (response.status === 401) {
          console.warn("🚨 [SESSION CHECK] 401 from backend → logout.");
          redirectToKeycloakLogout("401 from /validate-session");
          return;
        }

        let data = null;
        try {
          data = await response.json();
        } catch (e) {
          console.log("ℹ️ [SESSION CHECK] No JSON body, assuming OK.");
        }

        if (data && data.logout === true) {
          console.warn("🚨 [SESSION CHECK] logout:true from backend → logout.");
          redirectToKeycloakLogout("logout flag from backend");
          return;
        }

        console.log("✅ [SESSION CHECK] Session still valid (HTTP 200, no logout flag).");
      } catch (error) {
        console.error("❌ [SESSION CHECK] Error during fetch:", error);
        redirectToKeycloakLogout("Fetch error calling /validate-session");
      }
    }

    // --- Boot sequence --------------------------------------------------

    window.addEventListener("load", () => {
      console.log("🟢 [SESSION] window.load → captureTokens + first validateSession");
      captureTokens();
      validateSession();
    });

    document.addEventListener("DOMContentLoaded", () => {
      console.log("⏱️ [SESSION] DOMContentLoaded → start periodic checks (5s)");
      setInterval(() => {
        console.log("🔁 [SESSION] Periodic session validation tick");
        validateSession();
      }, 5000);
    });
  </script>
</head>
<%= content_tag :body,
                class: "#{body_css_classes}  __overflowing_element_container __overflowing_body",
                style: "#{!User.current.logged? ? 'padding: 0 !important' : ''}",
                data: body_data_attributes(local_assigns) do  %>
<%= render partial: 'warning_bar/warning_bar' %>
<noscript>
  <div class="top-shelf">
    <p>
      <span>
        <%= op_icon "icon3 icon-warning" %>
        <strong><%= t(:noscript_heading) %></strong>
      </span>
      <%= t(:noscript_description) %>
      <a href="http://www.enable-javascript.com/" target="_blank"><%= t(:noscript_learn_more) %></a>
    </p>
  </div>
</noscript>
<opce-toasts-container></opce-toasts-container>
<opce-modal-overlay></opce-modal-overlay>
<live-region>
  <div id="polite" aria-live="polite" aria-atomic="true" class="sr-only"></div>
  <div id="assertive" aria-live="assertive" aria-atomic="true" class="sr-only"></div>
</live-region>
<span id="open-blank-target-link-description" class="sr-only"><%= I18n.t("open_link_in_a_new_tab") %></span>
<opce-spot-drop-modal-portal></opce-spot-drop-modal-portal>
<% main_menu = render_main_menu(local_assigns.fetch(:menu_name, nil), @project) %>
<% side_displayed = content_for?(:sidebar) || content_for?(:main_menu) || !main_menu.blank? %>
<% initial_classes = initial_menu_classes(side_displayed, show_decoration) %>
<div id="wrapper" style="<%= initial_menu_styles %>" class="<%= initial_classes %>">
  <div id="main"
       class="<%= initial_classes %> d-flex"
       data-controller="menus--main-toggle">
    <% if (side_displayed && show_decoration) %>
      <div class="col-xxl-2 col-md-3 first-container" style="<%= !User.current.logged? ? 'width: 0%' : '' %>">
      <div
        id="main-menu"
        class="main-menu"
        data-controller="menus--main">
        <h1 class="sr-only"><%= t(:label_main_menu) %></h1>
        <%# <opce-main-menu-resizer></opce-main-menu-resizer> %>
        <div id="menu-sidebar">
          <div class="navbar-brand-box pl-1">
            <div class="op-logo--link">
              <%#= render_top_menu_center %>
            </div>
          </div>
          <div class="main-menu--top-container">
            <%= render(Primer::OpenProject::FlexLayout.new(align_items: :center, pt: 3)) do |flex|
              flex.with_column(overflow: :hidden) do
                render_projects_top_menu_node
              end
              # flex.with_column(text_align: :right, flex: :auto) do
              #   render(OpenProject::Common::MainMenuToggleComponent.new(expanded: true))
              # end
            end %>

            <%= render(
                  Primer::BaseComponent.new(
                    tag: :hr,
                    classes: "main-menu--projects-divider",
                    role: :presentation,
                    aria: {
                      hidden: true
                    }
                  )
                ) %>
          </div>
          <%= main_menu %>
          <%= content_for :main_menu %>
          <%= call_hook :view_layouts_base_main_menu %>
          <%=
            render(EnterpriseEdition::TrialTeaserComponent.new)
          %>
          <!-- Sidebar -->
          <div id="sidebar" data-menus--main-target="sidebar">
            <%= content_for :sidebar %>
            <%= call_hook :view_layouts_base_sidebar %>
          </div>
        </div>
      </div>
      </div>
    <% end %>
    <div class="col-xxl-10 col-md-9 second-container" style="<%= !User.current.logged? || !(side_displayed && show_decoration) ? 'width: 100%; padding: 0 !important;' : '' %>">
    <% if show_decoration && User.current.logged? %>
      <header class="op-app-header<%= " op-app-header_development" if OpenProject::Configuration.development_highlight_enabled? %>">
        <div class="op-app-header--start align-items-center">
          <h1 class="sr-only">
            <%= t(:label_top_menu) %>
          </h1>
          <%= render(OpenProject::Common::MainMenuToggleComponent.new(expanded: true)) %>
          <a href="" class="sr-only skip-navigation-link"
            id="skip-navigation--content"
            aria-label="<%= I18n.t("js.work_packages.jump_marks.label_content") %>">
            <%= I18n.t("js.work_packages.jump_marks.content") %>
          </a>
          <%= render_top_menu_left %>
        </div>
        <!-- <div class="op-app-header--center">
          <%#= render_top_menu_center %>
        </div> -->
        <div class="d-flex align-items-center">
          <a href="/">
            <%= image_tag "scalenowai-logo.png", alt: "logo", style: "width: 200px;", id: "desktop-view-logo" %>
            <%#= image_tag "scale-now-logo.png", alt: "logo", style: "height: 40px;", id: "mobile-view-logo" %>
          </a>
        </div>
        <div class="op-app-header--end">
          <%= call_hook :view_layouts_base_top_menu %>
          <%= render_top_menu_right %>
        </div>
      </header>
    <% end %>
    <div class="content-overlay"
         data-action="click->menus--main-toggle#toggleNavigation"></div>
    <%= content_tag :main, id: "content-wrapper", class: initial_classes, style: "#{!User.current.logged? ? 'height: 100% !important; min-height: 300px' : ''}", data: stimulus_content_data do %>
      <%= render partial: "layouts/flashes" %>
      <% if show_onboarding_modal? %>
        <section data-augmented-model-wrapper
                 data-modal-initialize-now="true"
                 data-modal-class-name="onboarding-modal">
          <%= render partial: "/onboarding/configuration_modal" %>
        </section>
      <% end %>
      <%= content_tag :div,
                      id: "content",
                      class: "#{initial_classes} #{'content--split' if content_for?(:content_body_right)}" do %>
        <h1 class="sr-only accessibility-helper"><%= t(:label_content) %></h1>
        <% if content_for?(:content_header) %>
          <div id="content-header">
            <%#= render(OpenProject::Common::MainMenuToggleComponent.new(expanded: false)) %>

            <%= content_for :content_header %>
          </div>
        <% end %>

        <div id="content-body">
          <%#= render(OpenProject::Common::MainMenuToggleComponent.new(expanded: false)) unless content_for?(:content_header) %>

          <%= content_for :content_body %>
          <% unless local_assigns[:no_layout_yield] %>
            <%= yield %>
          <% end %>
        </div>
        <%= turbo_frame_tag "content-bodyRight" do %>
          <%= content_for :content_body_right %>
        <% end %>
      <% end %>
    <% end %>
    </div>
  </div>
  <div id="ajax-indicator" style="display:none;"><span><%= t(:label_loading) %></span></div>
</div>
<%# Properly decides main menu expanded state and width before its drawn. Fixes flickering side menu
        where menu is first expanded, then being collapsed in angular. %>
<%= nonced_javascript_tag type: "module" do %>
  // execute these lines to prevent flickering when page loads:
  const wrapper = document.getElementById('wrapper');
  const mainMenuCollapsed = window.OpenProject.guardedLocalStorage('openProject-mainMenuCollapsed');

  let savedMainMenuWidth;
  if (mainMenuCollapsed === 'true') {
    savedMainMenuWidth = 0;
  } else {
    savedMainMenuWidth = parseInt(window.OpenProject.guardedLocalStorage('openProject-mainMenuWidth'), 10);
  }

  if (window.innerWidth < 1012) {
    // force hide on load for small desktops
    document.querySelector('.can-hide-navigation')?.classList.add('hidden-navigation');
  }

  if (savedMainMenuWidth >= 0) {
    document.documentElement.style.setProperty('--main-menu-width', savedMainMenuWidth + 'px');
  }

  wrapper.style.display = '';
<% end %>

<%= nonced_javascript_tag do %>
  (function($) {
    // Wrapper for page-specific JS from deprecated inline functions
    // no longer available with CSP.
    <%= content_for :additional_js_dom_ready %>

    $('.show-password-button').on('click', function() {
      // Get the password field
      var passwordField = $('#password-input');
      
      // Check the current type of the password field
      var passwordFieldType = passwordField.attr('type');
      
      // Toggle the type attribute
      if (passwordFieldType === 'password') {
        passwordField.attr('type', 'text');
      } else {
        passwordField.attr('type', 'password');
      }
    });

    $('#content-wrapper').on('scroll', function() {
      if ($(this).length) {
        $(this).css('padding-top', Math.max(0, 24 - $(this).scrollTop()) + 'px');
      }
    });
  }(jQuery));
<% end %>
<div class="op-wide-autocomplete-wrapper"></div>
<%= call_hook :view_layouts_base_body_bottom %>
<% end %>
</html>
