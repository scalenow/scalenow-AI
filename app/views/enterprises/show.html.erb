<% html_title t(:label_administration), t("admin.enterprise.upgrade_to_ee") %>

<div class="bg-white px-4 pt-4 mb-4 rounded-border" style="border: 1px solid #000;">
<%=
  render(Primer::OpenProject::PageHeader.new) do |header|
    header.with_title(classes: "color-orange") { t(:label_enterprise_edition) }
    header.with_breadcrumbs([{ href: admin_index_path, text: t(:label_administration) },
                             t(:label_enterprise_edition)])
  end
%>

<%= error_messages_for 'token' %>

<section class="form--section m-0">
<% if @current_token.present? %>
  <%= render partial: "current" %>
<% else %>
  <%= render partial: "info" %>
<% end %>
<%= render partial: "form" %>
</section>
</div>
